# AI Vision Model Configuration
# Choose one: openai, anthropic, ollama, omlx
AI_PROVIDER=omlx

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava

# oMLX (local, Apple Silicon)
# Available models:
# - mlx-community/llava-1.5-7b-4bit
# - mlx-community/llava-phi-3-mini-4bit
# - mlx-community/llava-phi-3-mini-8bit
# - mlx-community/llava-llama-3-8b-v1_1-4bit
# - mlx-community/llava-llama-3-8b-v1_1-8bit
# - mlx-community/llava-1.5-7b-8bit
# - mlx-community/llava-v1.6-mistral-7b-4bit
# - mlx-community/llava-v1.6-mistral-7b-8bit
OMLX_MODEL=mlx-community/llava-1.5-7b-4bit

# Server
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./home_catalogue.db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
