# AI Vision Model Configuration
# Choose one: openai, anthropic, ollama, lmstudio, omlx
AI_PROVIDER=ollama

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama (local — use host.docker.internal when backend runs in Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llava

# LM Studio (local, OpenAI-compatible API)
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=

# oMLX (local, Apple Silicon)
# Available models:
# - mlx-community/llava-1.5-7b-4bit
# - mlx-community/llava-phi-3-mini-4bit
# - mlx-community/llava-phi-3-mini-8bit
# - mlx-community/llava-llama-3-8b-v1_1-4bit
# - mlx-community/llava-llama-3-8b-v1_1-8bit
# - mlx-community/llava-1.5-7b-8bit
# - mlx-community/llava-v1.6-mistral-7b-4bit
# - mlx-community/llava-v1.6-mistral-7b-8bit
OMLX_MODEL=mlx-community/llava-1.5-7b-4bit

# Server
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:////app/storage/home_catalogue.db
UPLOAD_DIR=/app/storage/uploads
AI_SETTINGS_FILE=/app/storage/ai_settings.json
RUNNING_IN_DOCKER=1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
